# ─── Flask ────────────────────────────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string-in-production
FLASK_DEBUG=1

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection URL
DATABASE_URL=postgresql://logguard:password@localhost:5432/logguard_db

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-another-long-random-string
# Access token lifetime in minutes
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=30
# Refresh token lifetime in days
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=LogGuard <your-email@gmail.com>

# ─── Twilio (WhatsApp) ────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATELIMIT_STORAGE_URI=redis://localhost:6379/3

# ─── OTP ──────────────────────────────────────────────────────────────────────
# OTP expiry in minutes
OTP_EXPIRES_MINUTES=10

# ─── Account Lockout ──────────────────────────────────────────────────────────
MAX_FAILED_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# ─── Reports ──────────────────────────────────────────────────────────────────
REPORTS_DIR=reports

# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=LogGuard
FRONTEND_URL=http://localhost:3000
